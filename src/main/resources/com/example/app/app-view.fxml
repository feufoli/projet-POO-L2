<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.BorderPane?>

<?import javafx.scene.control.TextField?>


<BorderPane prefHeight="500.0" prefWidth="500.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="com.example.app.Controller1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <center>
        <ImageView fx:id="image1" fitWidth="300" preserveRatio="true">
            <image>
                <Image url="@welcome.png" />
            </image>
        </ImageView>
    </center>

    <left>
        <VBox prefWidth="150.0" spacing="25" style="-fx-background-color: #EDE8D0; -fx-border-color: #0000F0; -fx-border-width: 2;" >
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <Label fx:id="l_Selection" />
            <Button onAction="#Selection" text="selectionner" />
            <Button onAction="#SaveIT" text="save" />
            <Button onAction="#ResetFilters" text="reset filters" />
            <TextField fx:id="TagField">
                <text>Tag</text>
            </TextField>
            <Button onAction="#ResetTags" text="reset tags" />
            <Button onAction="#AddTag" text="ajouter tag" />

            <TextField fx:id="PassWordField">
                <text>mot de passe</text>
            </TextField>
            <Button onAction="#shuffle" text="melange" />
            <Button onAction="#unShuffle" text="retablir" />
        </VBox>
    </left>

    <right>
        <VBox prefWidth="150.0" spacing="25" style="-fx-background-color: #EDE8D0; -fx-border-color: #0000F0; -fx-border-width: 2;" >
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <Button onAction="#Rotate" text="rotate" />
            <Button onAction="#F_sepia" text="sépia" />
            <Button onAction="#F_miror" text="miror" />
            <Button onAction="#F_composant" text="composant" />
            <Button onAction="#F_blackWhite" text="Black and White" />
            <Button onAction="#F_prewitt" text="contour" />
        </VBox>
    </right>
</BorderPane>
